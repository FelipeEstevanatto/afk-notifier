AFK_SMTP_HOST=smtp.gmail.com
AFK_SMTP_PORT=587
AFK_SMTP_USER=emaildeenvio@gmail.com
AFK_SMTP_PASS=sua_senha_de_app
AFK_EMAIL_TO=emailderecebimento@gmail.com

# Tempo de inatividade (segundos) para disparar o aviso
AFK_LIMIT_SECONDS=30
# Intervalo de verificação (ms). Menor = aviso mais perto do limite exato
AFK_CHECK_INTERVAL_MS=1000